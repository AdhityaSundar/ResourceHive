generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resource {
  id          String   @id
  name        String
  category    String
  description String
  services    String[]
  address     String
  city        String
  state       String
  zip         String
  stateLocation String?
  phone       String
  email       String?
  contactName String?
  resourceInformation String?
  info        String?
  website     String
  hours       String
  languages   String[]
  tags        String[]
  latitude    Float
  longitude   Float
  eligibility String
  sourceType  String
  sourceRef   String?
  updatedAt   DateTime @updatedAt

  @@index([category, city])
  @@index([name])
}
